<header id="header" class="header">
    <div class="header-container">
        <div class="logo-container">
            <a class="logo" href="<%- url_for(theme.navitems.Home) %>">
                <img src="<%- url_for('/image/logo.svg') %>">
            </a>
        </div>
        <div class="menu">
            <% for (var i in theme.navitems) { %>
            <a class="navitems" href="<%- url_for(theme.navitems[i]) %>"><%= i %></a>
            <% } %>
        </div>
        <div id="moon-sun" class="moon-sun" onclick="switchDarkLightMode()">
            <i class="fa-solid fa-moon"></i>
        </div>
    </div>
</header>